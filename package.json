{
  "name": "hisaabai-backend",
  "version": "1.0.0",
  "description": "HisaabAI NestJS Backend",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "nest build",
    "build:railway": "node scripts/copy-prisma-client.js && nest build",
    "start": "node --max-old-space-size=512 server.js",
    "start:railway": "node server.js",
    "start:prod": "node --max-old-space-size=512 server.js",
    "start:dev": "nest start --watch",
    "install:cpanel": "npm install",
    "deploy:cpanel": "node \"${INIT_CWD}/scripts/copy-prisma-client.js\" && npm run build",
    "check:prisma": "node scripts/check-prisma.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "@prisma/client": "^5.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "csv-parser": "^3.0.0",
    "multer": "^1.4.4",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "prisma": "^5.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.0",
    "ts-loader": "^9.4.3",
    "typescript": "^5.0.0",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0"
  }
}
