{
  "name": "hisaabai-backend",
  "version": "1.0.0",
  "description": "HisaabAI Express.js Backend",
  "main": "server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "pm2-runtime start ecosystem.config.js",
    "dev": "nodemon --exec \"node --disable-wasm-trap-handler\" server.js",
    "db:push": "node scripts/db-push.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop hisaabai-backend",
    "pm2:restart": "pm2 restart hisaabai-backend",
    "pm2:logs": "pm2 logs hisaabai-backend",
    "pm2:status": "pm2 status"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "joi": "^17.12.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.0",
    "node-cron": "^3.0.3",
    "pm2": "^7.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
