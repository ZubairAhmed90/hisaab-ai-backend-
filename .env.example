# Database — use DATABASE_URL or individual vars
DATABASE_URL=mysql://user:password@localhost:3306/hisaabai
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=hisaabai

# JWT secrets
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Gold API
GOLD_API_KEY=your_gold_api_key_here

# Server
PORT=3001
NODE_ENV=production
# Your deployed Next.js URL (Vercel) — required for CORS
FRONTEND_URL=https://hisaabai.vercel.app

# cPanel / CloudLinux — prevents WebAssembly OOM crash on Node.js 20
# Add this in cPanel environment variables panel too
NODE_OPTIONS=--disable-wasm-trap-handler

# Cron (set to 'true' to disable market price scheduler)
DISABLE_CRON=false

# Admin user (auto-created on startup)
ADMIN_EMAIL=admin@hisaab.ai
ADMIN_PASSWORD=admin123
