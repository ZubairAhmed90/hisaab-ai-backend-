# ─── cPanel MySQL ─────────────────────────────────────────
# On the server (backend + DB on same cPanel): use localhost
# From your PC (remote dev): use the Remote MySQL hostname
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_cpanel_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_cpanel_db_name

# Prisma — encode special chars in password (@ → %40, # → %23)
DATABASE_URL="mysql://your_cpanel_db_user:your_db_password@localhost:3306/your_cpanel_db_name"

# ─── App ──────────────────────────────────────────────────
GROQ_API_KEY=""
JWT_SECRET="minimum-32-character-random-string"
JWT_REFRESH_SECRET="another-minimum-32-character-random-string"
GOLD_API_KEY=""
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://yourdomain.com"
