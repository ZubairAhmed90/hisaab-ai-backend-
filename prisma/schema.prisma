// HisaabAI — Prisma Schema
// DB: MySQL on cPanel
// Run: npx prisma migrate dev --name init

generator client {
  provider      = "prisma-client-js"
  output        = "./client"
  binaryTargets = ["native", "debian-openssl-1.0.x", "debian-openssl-1.1.x", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────
model User {
  id                 Int       @id @default(autoincrement())
  account_number     String?   @unique @db.VarChar(12)
  name               String    @db.VarChar(100)
  email              String    @unique @db.VarChar(150)
  password_hash      String    @db.VarChar(255)
  phone              String?   @db.VarChar(20)
  preferred_language String    @default("en") @db.VarChar(5)
  monthly_income     Decimal   @default(0) @db.Decimal(12, 2)
  wallet_balance     Decimal   @default(0) @db.Decimal(14, 2)
  account_balance    Decimal   @default(0) @db.Decimal(14, 2)
  is_admin           Boolean   @default(false)
  reset_token_hash   String?   @db.VarChar(255)
  reset_token_expires DateTime?
  created_at          DateTime  @default(now())
  last_login          DateTime?
  linked_partner_id   Int?

  transactions    Transaction[]
  budgets         Budget[]
  goals           Goal[]
  ai_insights     AiInsight[]
  report_cards    ReportCard[]
  offer_events    UserOfferEvent[]
  linked_partner  User?           @relation("UserPartners", fields: [linked_partner_id], references: [id])
  partner_of      User[]          @relation("UserPartners")
  limits_set      SpendingLimit[] @relation("LimitOwner")
  limits_received SpendingLimit[] @relation("LimitTarget")
  holdings        UserHolding[]
  stock_trades    StockTrade[]

  @@map("users")
}

// ─── Spending Limits ──────────────────────────────────────
model SpendingLimit {
  id               Int      @id @default(autoincrement())
  owner_id         Int
  target_user_id   Int
  category         String   @db.VarChar(50)
  monthly_limit    Decimal  @db.Decimal(12, 2)
  alert_at_percent Int      @default(80)
  is_hard_limit    Boolean  @default(true)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())

  owner       User @relation("LimitOwner", fields: [owner_id], references: [id], onDelete: Cascade)
  target_user User @relation("LimitTarget", fields: [target_user_id], references: [id], onDelete: Cascade)

  @@unique([owner_id, target_user_id, category])
  @@map("spending_limits")
}

// ─── Transactions ─────────────────────────────────────────
model Transaction {
  id               Int      @id @default(autoincrement())
  user_id          Int
  amount           Decimal  @db.Decimal(12, 2)
  description      String   @db.VarChar(255)
  category         String   @default("other") @db.VarChar(50)
  sub_category     String?  @db.VarChar(50)
  merchant         String?  @db.VarChar(100)
  transaction_date DateTime @db.Date
  source           String   @default("manual") @db.VarChar(20)
  is_recurring     Boolean  @default(false)
  ai_confidence    Decimal? @db.Decimal(3, 2)
  user_corrected   Boolean  @default(false)
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, transaction_date])
  @@map("transactions")
}

// ─── Budgets ──────────────────────────────────────────────
model Budget {
  id               Int      @id @default(autoincrement())
  user_id          Int
  category         String   @db.VarChar(50)
  monthly_limit    Decimal  @db.Decimal(12, 2)
  month            DateTime @db.Date
  alert_at_percent Int      @default(80)
  created_at       DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category, month])
  @@map("budgets")
}

// ─── Goals ────────────────────────────────────────────────
model Goal {
  id             Int      @id @default(autoincrement())
  user_id        Int
  title          String   @db.VarChar(150)
  target_amount  Decimal  @db.Decimal(12, 2)
  saved_amount   Decimal  @default(0) @db.Decimal(12, 2)
  deadline       DateTime @db.Date
  status         String   @default("active") @db.VarChar(20)
  created_at     DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("goals")
}

// ─── Market Cache ─────────────────────────────────────────
model MarketCache {
  id          Int      @id @default(autoincrement())
  asset_type  String   @db.VarChar(20)
  ticker      String   @db.VarChar(20)
  price_pkr   Decimal  @db.Decimal(12, 4)
  change_1d   Decimal? @db.Decimal(6, 4)
  change_30d  Decimal? @db.Decimal(6, 4)
  change_90d  Decimal? @db.Decimal(6, 4)
  change_180d Decimal? @db.Decimal(6, 4)
  change_365d Decimal? @db.Decimal(6, 4)
  fetched_at  DateTime @default(now())

  @@unique([asset_type, ticker])
  @@map("market_cache")
}

// ─── User Portfolio Holdings ──────────────────────────────
model UserHolding {
  id           Int      @id @default(autoincrement())
  user_id      Int
  ticker       String   @db.VarChar(20)
  display_name String   @db.VarChar(100)
  asset_type   String   @default("stock") @db.VarChar(20)
  quantity     Decimal  @db.Decimal(12, 4)
  avg_cost_pkr Decimal  @db.Decimal(12, 4)
  acquired_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, ticker])
  @@map("user_holdings")
}

// ─── Stock Trades (buy / sell ledger) ─────────────────────
model StockTrade {
  id           Int      @id @default(autoincrement())
  user_id      Int
  ticker       String   @db.VarChar(20)
  display_name String   @db.VarChar(100)
  side         String   @db.VarChar(4)
  quantity     Decimal  @db.Decimal(12, 4)
  price_pkr    Decimal  @db.Decimal(12, 4)
  total_pkr    Decimal  @db.Decimal(14, 2)
  created_at   DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("stock_trades")
}

// ─── AI Insights ──────────────────────────────────────────
model AiInsight {
  id           Int      @id @default(autoincrement())
  user_id      Int
  type         String   @db.VarChar(30)
  content_en   String   @db.Text
  content_ur   String?  @db.Text
  is_read      Boolean  @default(false)
  rating       String?  @db.VarChar(10)
  generated_at DateTime @default(now())
  valid_until  DateTime?

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("ai_insights")
}

// ─── Report Cards ─────────────────────────────────────────
model ReportCard {
  id             Int      @id @default(autoincrement())
  user_id        Int
  month          DateTime @db.Date
  overall_grade  String   @db.VarChar(5)
  budget_score   Int
  savings_score  Int
  trend_score    Int
  summary_en     String   @db.Text
  summary_ur     String?  @db.Text
  created_at     DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, month])
  @@map("report_cards")
}

// ─── Offer Partners ───────────────────────────────────────
model OfferPartner {
  id             Int      @id @default(autoincrement())
  company_name   String   @db.VarChar(100)
  category       String   @db.VarChar(50)
  billing_model  String   @db.VarChar(10)
  rate_pkr       Decimal  @db.Decimal(10, 2)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())

  offers Offer[]

  @@map("offer_partners")
}

// ─── Offers ───────────────────────────────────────────────
model Offer {
  id                   Int      @id @default(autoincrement())
  partner_id           Int
  title                String   @db.VarChar(150)
  title_ur             String?  @db.VarChar(150)
  description          String   @db.Text
  target_category      String   @db.VarChar(50)
  min_monthly_spend    Decimal  @db.Decimal(10, 2)
  trigger_event        String   @db.VarChar(50)
  promo_code           String?  @db.VarChar(50)
  redemption_type      String   @default("code") @db.VarChar(20)
  deeplink_url         String?  @db.VarChar(255)
  valid_from           DateTime @db.Date
  valid_until          DateTime @db.Date
  max_redemptions      Int      @default(1000)
  current_redemptions  Int      @default(0)
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now())

  partner OfferPartner     @relation(fields: [partner_id], references: [id])
  events  UserOfferEvent[]

  @@map("offers")
}

// ─── User Offer Events ────────────────────────────────────
model UserOfferEvent {
  id           Int      @id @default(autoincrement())
  user_id      Int
  offer_id     Int
  event_type   String   @db.VarChar(20)
  spend_amount Decimal? @db.Decimal(10, 2)
  event_at     DateTime @default(now())

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  offer Offer @relation(fields: [offer_id], references: [id], onDelete: Cascade)

  @@map("user_offer_events")
}
